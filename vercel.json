{
  "version": 2,
  "name": "decoroute",
  "builds": [
    {
      "src": "index.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/",
      "dest": "/index.html"
    },
    {
      "src": "/api/(.*)",
      "dest": "https://decoroute-api.onrender.com/api/$1"
    }
  ],
  "env": {
    "API_URL": "https://decoroute-api.onrender.com"
  }
}